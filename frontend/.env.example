# Desenvolvimento: não é obrigatório — o Vite usa proxy /api → localhost:8000.
#
# Produção: copie este arquivo para .env.production antes do npm run build:
#   cp .env.example .env.production
# Edite VITE_API_URL para a URL pública da API (HTTPS, sem barra no final).

# VITE_API_URL=https://api.seudominio.com
