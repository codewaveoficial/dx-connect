# Copie para .env:  cp .env.example .env  (desenvolvimento local)

ENVIRONMENT=development
DEBUG=false
DATABASE_URL=postgresql://dxconnect:dxconnect_secret@localhost:5432/dxconnect
# Desenvolvimento: 16+ caracteres. Produção: 32+ e valor aleatório forte.
SECRET_KEY=local-dev-secret-min-16-chars
ALGORITHM=HS256
# Desenvolvimento: até 60. Em ENVIRONMENT=production o app exige no máximo 30 (sessão curta / JWT).
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Separadas por vírgula. Em produção use apenas origens HTTPS reais do frontend.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

LOG_LEVEL=INFO

# Cache IBGE (municípios): intervalo entre syncs em segundos e idade máxima (horas) antes de re-sync.
# IBGE_MUNICIPIOS_SYNC_INTERVAL_SECONDS=86400
# IBGE_MUNICIPIOS_MAX_AGE_HOURS=168

# --- Produção (Hostinger / DB externo), exemplo ---
# ENVIRONMENT=production
# DEBUG=false
# DATABASE_URL=postgresql://usuario:senha@host-da-hostinger:5432/nome_db?sslmode=require
# Se Postgres estiver no mesmo VPS e a API rodar com docker-compose.prod (network_mode: host), use 127.0.0.1 no host.
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# ALLOWED_HOSTS=api.seudominio.com,127.0.0.1
# SECRET_KEY=cole_aqui_hex_de_64_chars_ou_base64_forte
# CORS_ORIGINS=https://app.seudominio.com,https://www.seudominio.com
#
# Deploy produção (schema):
# - Subir API só após aplicar migrations no banco:  alembic upgrade head
#   (ex.: docker compose run --rm backend alembic upgrade head — ver docker-compose.)
# - Com ENVIRONMENT=production a API NÃO roda SQLAlchemy create_all nem seed automático;
#   evita conflito com Alembic e criação de admin padrão sem você querer.
# - Dados iniciais (status de ticket, primeiro admin): rode uma vez, com controle:
#     docker compose exec backend python -m app.seed
#   Em produção defina SEED_ADMIN_EMAIL e SEED_ADMIN_PASSWORD (mín. 8 caracteres) para criar o primeiro admin;
#   a conta nasce com must_change_password=true (troca obrigatória na primeira sessão).
#   Sem SEED_ADMIN_EMAIL (ou sem senha válida) o seed em produção não cria usuário admin automático.
#
# SEED_ADMIN_EMAIL=seu@email.com
# SEED_ADMIN_PASSWORD=

# Hostnames permitidos no header Host (TrustedHostMiddleware). Em produção liste o hostname da API e 127.0.0.1 se
# fizer healthcheck local. Não use * em produção.
# ALLOWED_HOSTS=api.seudominio.com,127.0.0.1
#
# Gunicorn: IPs que podem enviar X-Forwarded-* (padrão 127.0.0.1). Se o Nginx estiver noutro host, defina o IP do proxy.
# GUNICORN_FORWARDED_ALLOW_IPS=127.0.0.1
#
# JWT: só access token (sem refresh). Token em localStorage/sessionStorage é sensível a XSS — mantenha dependências
# atualizadas (npm audit no frontend), CSP no Nginx, e evite innerHTML com dados não confiáveis. Refresh em cookie
# httpOnly exige mudança maior de backend; avalie conforme o perfil de risco.
#
# Cabeçalhos extras (HSTS, CSP no HTML) e limit_req em /auth/login: ver deploy/nginx/README.md
